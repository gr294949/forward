[Rewrite]
^https:\/\/yunmai\.sfo-tx-beijing-02\.saas\.sensorsdata\.cn\/api\/v2\/sfo\/user_popup_configs\? reject-dict

^https:\/\/apisvr\.iyunmai\.com\/api\/ios\/apps\/get-online-parameter-list\.json\? response-body-json-jq '.data.rows |= map(select(.name | IN("AC_startTime","AC_endTime","AC_enable","AC_url","AC_challenge_tip","AC_challenge_tip_id","AC_pt_tip","AC_pt_tip_id","AC_pt_go_tmall_jd","month7_activity","AC_xmas_isOpen","home_show_info","new_user_credit_exchange_info","AC_share_recommendUrl","AC_share_recommendUrl_2","AC_share_recommendUrl_3") | not))'

^https:\/\/restapi\.iyunmai\.com\/ad-api\/ reject-dict

^https:\/\/apisvr\.iyunmai\.com\/api\/ios\/first-page-module\/center_menu\.json\? reject-dict
^https:\/\/restapi\.iyunmai\.com\/api\/ios\/ad\/ reject-dict

[MitM]
hostname=yunmai.sfo-tx-beijing-02.saas.sensorsdata.cn, apisvr.iyunmai.com, restapi.iyunmai.com